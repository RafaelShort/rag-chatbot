# RAG System — Variaveis de Ambiente
# Copie este arquivo para backend/.env e ajuste os valores
# cp .env.example backend/.env

# LLM
# Opcao 1: Ollama (local, gratuito)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Opcao 2: OpenAI (requer API key paga)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-3.5-turbo
# OPENAI_API_KEY=sk-your-key-here

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Embeddings
# Opcao 1: Local (sentence-transformers, gratuito)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Opcao 2: OpenAI Embeddings
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNKING_STRATEGY=sliding_window

# Retrieval
RETRIEVAL_TOP_K=10
RERANKER_TOP_K=3
USE_RERANKER=false

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
